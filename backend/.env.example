# ── 資料庫設定（PostgreSQL）─────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
# REQUIRED — 至少 8 字元,不可為 admin123 / changeme / password / secret 等弱值。
# 產生:`openssl rand -hex 24`
DB_PASSWORD=
DB_NAME=autotest_db

# ── Cache + Celery broker + WebSocket pub/sub（Valkey；Redis-compatible）──
REDIS_URL=redis://localhost:6379/0

# ── 截圖存放目錄（本機資料夾）────────────────────────────────
PIC_FOLDER=./PIC

# ── 物件儲存(SeaweedFS S3 API)──────────────────────────────
# 透過 docker-compose 啟動時,backend 由 S3_ROOT_PASSWORD 映射而來;直接跑
# backend(非 compose)時須手動設。Access key 沿用 admin。
S3_ENDPOINT=http://seaweedfs:8333
S3_ACCESS_KEY=admin
# REQUIRED — 至少 8 字元,不可為 admin123 / changeme / password / secret。
S3_SECRET_KEY=

# ── 應用程式 ─────────────────────────────────────────────────
BASE_URL=http://localhost:8000
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True

# v1.1.13:本機直接跑 backend(不透過 gateway)時保持 False,否則所有 /api/*
# 一律 401。Docker compose 部署預設改 True(見根 .env.example)。
BACKEND_TRUST_GATEWAY_ONLY=False
