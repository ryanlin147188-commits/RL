# 提供給 docker-compose 讀取的環境變數預設值
# Stack：PostgreSQL（DB）/ Valkey（cache & broker）/ SeaweedFS（S3 物件儲存）
# 預設帳密統一為 admin / admin123
DB_USER=admin
DB_PASSWORD=admin123
DB_NAME=autotest_db
BASE_URL=http://localhost
# STORAGE_BACKEND：local（FastAPI 直接服務 PIC volume）/ minio（S3，後端為 SeaweedFS）
STORAGE_BACKEND=minio
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin123
