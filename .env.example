# ============================================================================
# AutoTest environment variables — example
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values, OR (recommended) run
# `./deploy.sh` (Linux/macOS) or `.\deploy.ps1` (Windows) — those scripts
# auto-generate `.env` with strong random secrets the first time they run.
#
# Never commit `.env` to git. The `.gitignore` already excludes it.
# ============================================================================

# ── PostgreSQL ──────────────────────────────────────────────────────────────
DB_USER=admin
DB_PASSWORD=                           # REQUIRED. Pick a long random value.
DB_NAME=autotest_db

# ── Object storage (SeaweedFS S3-compatible) ────────────────────────────────
# Only 's3' is supported — the platform stores all uploads in SeaweedFS via
# its S3 API. Earlier versions accepted 'local' / 'minio'; both removed.
STORAGE_BACKEND=s3
S3_ROOT_USER=admin
S3_ROOT_PASSWORD=                      # REQUIRED. Pick a long random value.

# ── External URL & CORS ─────────────────────────────────────────────────────
BASE_URL=http://localhost
# CORS allow-list, comma-separated. NEVER use "*" in production. Override per
# deployment to your front-end's actual origin(s), e.g.:
#   ALLOWED_ORIGINS=https://autotest.example.com,https://staging.example.com
ALLOWED_ORIGINS=http://localhost

# ── Application secrets (REQUIRED — do not leave blank) ─────────────────────
# JWT signing key. Generate with: openssl rand -hex 32
AUTOTEST_JWT_SECRET=
# Fernet symmetric key (urlsafe base64 of 32 random bytes). Used for at-rest
# encryption of SMTP passwords, AI provider keys, etc. Generate with:
#   python -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
AUTOTEST_FERNET_KEY=

# ── Image tags (locally built; pin to a specific version, never `latest`) ───
# Override only if you build custom images.
# RECORDER_IMAGE=autotest-recorder:1.0.0
# ROBOT_RUNNER_IMAGE=autotest-robot-runner:1.0.0

# ── Optional: bootstrap admin via CLI (non-interactive) ─────────────────────
# Used by `python -m app.cli create-admin --non-interactive`.
# Leave blank to use the interactive prompt instead.
# AUTOTEST_ADMIN_USERNAME=
# AUTOTEST_ADMIN_PASSWORD=
# AUTOTEST_ADMIN_EMAIL=
