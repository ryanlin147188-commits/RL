# ============================================================================
# AutoTest environment variables — example
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values, OR (recommended) run
#   docker compose --profile init run --rm bootstrap
# which auto-generates `.env` with strong random secrets the first time it
# runs (skips if `.env` already exists).
#
# Never commit `.env` to git. The `.gitignore` already excludes it.
# ============================================================================

# ── PostgreSQL ──────────────────────────────────────────────────────────────
DB_USER=admin
DB_PASSWORD=                           # REQUIRED. Pick a long random value.
DB_NAME=autotest_db

# ── Object storage (SeaweedFS S3-compatible) ────────────────────────────────
# Only 's3' is supported — the platform stores all uploads in SeaweedFS via
# its S3 API. Earlier versions accepted 'local' / 'minio'; both removed.
STORAGE_BACKEND=s3
S3_ROOT_USER=admin
S3_ROOT_PASSWORD=                      # REQUIRED. Pick a long random value.

# ── External URL & CORS ─────────────────────────────────────────────────────
# BASE_URL 是對外可訪問的 root URL,OIDC redirect_uri 會由此推導。
# 非 localhost 部署必須使用 https://(否則啟動會 fail-fast,避免 MitM)。
BASE_URL=http://localhost
# CORS allow-list, comma-separated. NEVER use "*" in production. Override per
# deployment to your front-end's actual origin(s), e.g.:
#   ALLOWED_ORIGINS=https://autotest.example.com,https://staging.example.com
ALLOWED_ORIGINS=http://localhost

# Set to True only for local debugging; production should keep this False.
AUTOTEST_DEBUG=False

# ── Application secrets (REQUIRED — do not leave blank) ─────────────────────
# JWT signing key. Generate with: openssl rand -hex 32
AUTOTEST_JWT_SECRET=
# Fernet symmetric key (urlsafe base64 of 32 random bytes). Used for at-rest
# encryption of SMTP passwords, AI provider keys, etc. Generate with:
#   python -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
AUTOTEST_FERNET_KEY=
# Gateway ↔ Backend HMAC secret. v1.1.13 起強制必填(無 secret 會讓繞
# gateway 的請求跳過限流/revocation 檢查)。Generate with: openssl rand -hex 32
GATEWAY_BACKEND_SHARED_SECRET=
# v1.1.13 起預設 True:啟用後缺合法 gateway HMAC 的 /api/* 請求一律 401。
# 配合 docker-compose 沒對 host publish backend:8000,完成「信任邊界 = gateway」收斂。
# Public paths(/healthz、/pics、/results、/api/recordings/.../upload(-har))不受影響。
# 本機開發若需 `curl backend:8000/api/...` 直接除錯,改成 False。
BACKEND_TRUST_GATEWAY_ONLY=True

# ── Image tags (locally built; pin to a specific version, never `latest`) ───
# Override only if you build custom images.
# RECORDER_IMAGE=autotest-recorder:1.0.0
# ROBOT_RUNNER_IMAGE=autotest-robot-runner:1.0.0

# ── Optional: bootstrap admin via CLI (non-interactive) ─────────────────────
# Used by `python -m app.cli create-admin --non-interactive`.
# Leave blank to use the interactive prompt instead.
# AUTOTEST_ADMIN_USERNAME=
# AUTOTEST_ADMIN_PASSWORD=
# AUTOTEST_ADMIN_EMAIL=

# ── AI Agent / LLM providers ────────────────────────────────────────────────
# Phase 0 暫時從 env 讀;Phase 0 後半段會搬到 DB(Fernet 加密)。空 = 該供應商停用。
# Anthropic Claude:https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# OpenAI ChatGPT:https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Google AI Studio (Gemini):https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# 接 OpenAI-compatible 本地推論(vLLM / Ollama / LM Studio)才填,否則留空走官方
# OPENAI_BASE_URL=http://ollama:11434/v1/chat/completions
# 預設模型(呼叫端可 override);建議 claude-opus-4-7 因 prompt caching 收益最大
AGENT_DEFAULT_MODEL=claude-opus-4-7
# LLM HTTP 整體 timeout(秒)。長 tool 走 Celery,不在這 block。
LLM_HTTP_TIMEOUT_SEC=60
# Phase 2 風險紅線:每 organization 每月 LLM 用量上限(USD)。<=0 = 不檢查
AGENT_BUDGET_USD_PER_MONTH=50
# planner / analyzer 自主 agent 走 chat 上限 × multiplier 的獨立 cap
AGENT_AUTONOMOUS_BUDGET_MULTIPLIER=2.0

# ── mem0 sidecar(v1.2.x 跨 session 長期記憶) ────────────────────────────────
# backend 與 sidecar 之間用 shared secret 雙向驗證;留空 = 不啟用 mem0(send_message
# 仍正常,只是沒有跨 session 記憶)。
# Generate with: openssl rand -hex 32
MEM0_SIDECAR_AUTH=
# sidecar 內部 URL(只在 docker network 內;不對外公開)
MEM0_SIDECAR_URL=http://mem0-sidecar:7900
