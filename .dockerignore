# ============================================================================
# .dockerignore — 供 Dockerfile.bundle build 時精簡 build context
# （注意：backend/Dockerfile 自己有 COPY 行為，也會被這份忽略表影響；
#   但既有 backend build 已使用 COPY requirements.txt + COPY app/ + COPY tasks/
#   明確指定需要哪些檔案，所以排除下列內容是安全的。）
# ============================================================================

# Git / 版本控制
.git
.gitignore
.gitattributes

# 本機產生物 / 記錄 / 暫存
PIC/
record/
*.log
.venv/
venv/
__pycache__/
**/__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
node_modules/

# IDE 設定
.vscode/
.idea/
*.swp

# 計畫 / 快取 / macOS / Windows 系統檔
.DS_Store
Thumbs.db
c:/Users/*/.claude

# 既有 compose 執行後產生的東西（若有）
.tmp_check/

# 已上傳的測試資料（正式部署不需要）
tests_data/archive/

# 不把自己打進去（避免遞迴）
Dockerfile.bundle
.dockerignore
